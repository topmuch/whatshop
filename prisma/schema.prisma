// Boutiko SaaS - Multi-tenant e-commerce for African merchants
// Architecture: Subscription linked to USER (not shop), multi-shop per user, reseller white-label

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────────

enum Role {
  SELLER
  ADMIN
  SUPER_ADMIN
  RESELLER
}

enum PlanType {
  STARTER  // 5000F — 1 boutique
  PRO      // 8000F — 3 boutiques
  BUSINESS // 20000F — 10 boutiques + domaine personnalisé
}

enum SubStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

// ─── USER ──────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  role        Role     @default(SELLER)
  isSuspended Boolean  @default(false)
  suspendedAt DateTime?
  suspendedReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  shops           Shop[]
  orders          Order[]
  domainReviews   DomainRequest[] @relation("DomainReview")
  subscription    Subscription?
  resellerProfile Reseller?
  resellerClients User[]           @relation("ResellerClients")
  resellerId      String?
  reseller        User?            @relation("ResellerClients", fields: [resellerId], references: [id])
  upgradeRequests  UpgradeRequest[]
  reviewedUpgrades UpgradeRequest[] @relation("UpgradeReviews")
  notifications    Notification[]
  pushSubscriptions PushSubscription[]
}

// ─── SUBSCRIPTION (liée au COMPTE UTILISATEUR, pas à la boutique) ─────────────

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  planType         PlanType  @default(STARTER)
  status           SubStatus @default(TRIAL)
  maxShops         Int       @default(1)
  startDate        DateTime  @default(now())
  endDate          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── RESELLER (White-label) ────────────────────────────────────────────────────

model Reseller {
  id           String   @id @default(cuid())
  userId       String   @unique
  companyName  String?
  logoUrl      String?
  primaryColor String   @default("#EC4899")
  commission   Int      @default(10) // pourcentage de commission
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── SHOP (multi-boutiques par utilisateur) ────────────────────────────────────

model Shop {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String   @unique
  description           String?
  logo                  String?
  banner                String?
  whatsapp              String
  address               String?
  phone                 String?
  plan                  String   @default("TRIAL") // TRIAL | FREE | PRO
  trialEndDate          DateTime?
  businessType          String   @default("ECOMMERCE") // ECOMMERCE | SERVICE
  sector                String?  // ECOMMERCE: beaute, mode, electronique, alimentation, autre | SERVICE: beaute-service, restaurant, consulting, artisanat, sante
  isRestaurant          Boolean  @default(false) // Activates menu QR code feature
  qrCodeUrl             String?  // Stored SVG menu QR code (base64 or path)
  template              String   @default("xstore-electro")
  accentColor           String   @default("#10B981")
  isActive              Boolean  @default(true)
  ownerId               String   // NO @unique — allows multiple shops per user

  // SEO & Open Graph
  seoTitle              String?
  seoDescription        String?
  seoKeywords           String?
  ogImage               String?
  coverImageUrl         String?

  // Hero Slider (JSON array of image URLs)
  heroImages            String   @default("[]")

  // Promo Banners (JSON array of {image, title, link, position} objects)
  promoBanners          String   @default("[]")

  // Brands Carousel (JSON array of {name, image, link} objects)
  brands                String   @default("[]")

  // Custom Domain
  customDomain           String?   @unique
  customDomainStatus     String?   @default("NONE") // NONE | PENDING | APPROVED | REJECTED
  customDomainRejectionReason String?

  // Subscription (manual management — legacy, kept for backward compat)
  subscriptionStatus     String?   @default("TRIAL") // TRIAL | ACTIVE | SUSPENDED | EXPIRED | CANCELLED
  subscriptionEndDate    DateTime?

  // Referral
  referredById          String?

  // Marketing & Branding colors
  primaryColor          String   @default("#EC4899")
  secondaryColor        String?
  customColors          String   @default("{}")  // JSON: { primary?, secondary?, accent? } overrides template defaults

  // Cosmika Beauty template customization
  heroTitle             String?
  heroSubtitle          String?
  heroTagline           String?
  heroImageUrl          String?
  consultantPhotoUrl    String?   // Consulting: photo du consultant affichée dans le hero
  aboutText             String?   // Consulting: description longue "Qui sommes-nous"
  contactEmail          String?   // Email de contact
  businessHours         String?   // Horaires d'ouverture
  googleMapsUrl         String?   // URL d'intégration Google Maps
  productsTitle         String?
  productsTagline       String?
  categoriesTitle       String?
  categoriesTagline     String?
  testimonialsTitle     String?
  testimonialsTagline   String?
  trustBadges           String   @default("[]")  // JSON array of {emoji, title, subtitle, order}
  footerLinks           String   @default("[]")  // JSON array of {section, label, url}

  // Notification preferences
  notificationPreferences String   @default("{}") // JSON: { newOrder: true, lowStock: false, ... }
  notificationEmail       String?

  // Analytics counters
  whatsappClicks        Int       @default(0)
  contactFormSubmits    Int       @default(0)
  pageViews             Int       @default(0)

  // Facebook Integrations (simplified)
  facebookConnected     Boolean   @default(false)
  facebookPageId        String?
  facebookPageName      String?
  facebookPixelId       String?
  facebookAccessToken   String?   // Encrypted — for Pixel + CAPI
  facebookCatalogId     String?   // Facebook Commerce Manager catalog ID

  // Catalog sync configuration
  catalogEnabled        Boolean   @default(false)
  catalogLastSync       DateTime?
  catalogProductCount   Int       @default(0)

  // Live mode (simple: 1 product spotlight, no Socket.IO needed)
  isLiveMode            Boolean  @default(false)
  liveProductId         String?
  liveStartedAt         DateTime?

  // Tracking configuration
  trackPageViews        Boolean   @default(true)
  trackProductViews     Boolean   @default(true)
  trackWhatsAppClicks   Boolean   @default(true)

  // Moderation
  isFlagged              Boolean   @default(false)
  flaggedReason          String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  owner     User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  referee  Shop?             @relation("Referral", fields: [referredById], references: [id])
  referrals Shop[]           @relation("Referral")
  categories   Category[]
  products     Product[]
  visits       Visit[]
  orders       Order[]
  liveSession  LiveSession?
  domainRequest DomainRequest?
  supportTickets SupportTicket[]
  shippingZones ShippingZone[]
  marketingAssets MarketingAsset[]
  testimonials   Testimonial[]
  contactMessages ContactMessage[]
  analyticsEvents AnalyticsEvent[]
  facebookEvents   FacebookEvent[]
  socialPosts     SocialPost[]
}

// ─── CATEGORY ──────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  image       String?
  shopId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products Product[]
}

// ─── TESTIMONIAL ─────────────────────────────────────────────────────────────

model Testimonial {
  id           String   @id @default(cuid())
  shopId       String
  clientName   String
  clientAvatar String?
  clientRole   String?   // Poste du client: "CEO, StartupXYZ"
  comment      String
  rating       Int      @default(5)
  isDisplayed  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

// ─── CONTACT MESSAGE ──────────────────────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("NEW") // NEW, READ, REPLIED
  source    String   @default("FORM") // FORM, WHATSAPP, CALL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([status])
}

// ─── PRODUCT ───────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String?
  shortDescription String?
  description String?
  price       Float
  image       String?
  images      String   @default("[]") // JSON array of image URLs
  stock       Int?
  isAvailable Boolean  @default(true)
  isFeatured  Boolean  @default(false) // Used by Smart Link /go/[slug]
  shopId      String
  categoryId  String?

  // Analytics
  whatsappClicks Int    @default(0)
  views          Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId, slug])

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  socialPosts SocialPost[]
  orderItems OrderItem[]
}

// ─── ORDER ─────────────────────────────────────────────────────────────────────

model Order {
  id              String   @id @default(cuid())
  shopId          String
  items           String   // JSON array of {productId, name, price, quantity} (legacy compat)
  total           Float
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  customerAddress String?
  customerCity    String?
  customerNotes   String?
  status          String   @default("PENDING") // PENDING | CONFIRMED | DELIVERED | CANCELLED
  createdAt       DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])
  userId String?
  orderItems      OrderItem[]
}

// ─── ORDER ITEM (relational) ───────────────────────────────────────────────

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String?
  productName  String
  price       Float
  quantity    Int
  createdAt   DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// ─── VISIT ─────────────────────────────────────────────────────────────────────

model Visit {
  id        String   @id @default(cuid())
  shopId    String
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

// ─── ANALYTICS EVENT ─────────────────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  shopId    String
  eventType String   // 'whatsapp_click', 'form_submit', 'page_view', 'product_view'
  metadata  String?  // JSON: { productId?, path?, productName? }
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([eventType])
  @@index([createdAt])
}

// ─── LIVE SESSION ──────────────────────────────────────────────────────────────

model LiveSession {
  id              String   @id @default(cuid())
  shopId          String   @unique
  isActive        Boolean  @default(false)
  endTime         DateTime?
  pinnedProductId String?
  whatsappClicks  Int      @default(0)
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop        Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  promoCodes  LivePromoCode[]
  leads       Lead[]
}

model LivePromoCode {
  id              String   @id @default(cuid())
  sessionId       String
  code            String
  discountPercent Int
  isActive        Boolean  @default(true)
  usedCount       Int      @default(0)
  createdAt       DateTime @default(now())

  session     LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Lead {
  id        String   @id @default(cuid())
  sessionId String
  phone     String
  name      String?
  createdAt DateTime @default(now())

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ─── SaaS CONFIGURATION (Singleton) ────────────────────────────────────────────

model SaaSConfig {
  id                     String   @id @default(cuid())
  saasName               String   @default("Boutiko")
  primaryColor           String   @default("#EC4899")
  logoUrl                String?
  defaultWhatsappMessage String   @default("Bonjour, je souhaite commander le produit: {productName} - {productPrice} FCFA depuis votre boutique Boutiko.")
  // Plans pricing (FCFA)
  starterPrice           Int      @default(5000)
  proPrice               Int      @default(8000)
  businessPrice          Int      @default(20000)
  // Legacy fields (kept for backward compat)
  standardPrice          Int      @default(5000)
  proLegacyPrice         Int      @default(10000)
  adminWhatsAppNumber    String?
  // Notification settings
  supportEmail           String?
  // SMTP Configuration (encrypted at rest)
  smtpHost               String?
  smtpPort               Int      @default(587)
  smtpUser               String?
  smtpPass               String?
  emailFrom              String?
  emailFromName          String?
  smtpConfigured         Boolean  @default(false)
  senderName             String?
  autoWelcomeEmail       Boolean  @default(true)
  notifyNewSeller        Boolean  @default(true)
  notifyNewOrder         Boolean  @default(true)
  notifyDomainRequest    Boolean  @default(false)
  notifySupportTicket    Boolean  @default(true)
  weeklyReport           Boolean  @default(false)
  lowStockAlerts         Boolean  @default(false)
  // Moderation
  forbiddenKeywords     String   @default("") // JSON array of forbidden words for shop names, product names
  createdAt              DateTime @default(now())
  updatedAt              DateTime  @updatedAt
}

// ─── PROMO CODES (SaaS-level) ─────────────────────────────────────────────────

model PromoCode {
  id             String    @id @default(cuid())
  code           String    @unique
  discountPercent Int
  maxUses        Int
  currentUses    Int       @default(0)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── CUSTOM DOMAIN REQUESTS ────────────────────────────────────────────────────

model DomainRequest {
  id              String   @id @default(cuid())
  shopId          String   @unique
  domain          String   @unique
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectionReason String?
  dnsInstructions String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop    Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  reviewerId String?
  reviewer  User?   @relation("DomainReview", fields: [reviewerId], references: [id])
}

// ─── SUPPORT TICKETS ──────────────────────────────────────────────────────────

model SupportTicket {
  id        String   @id @default(cuid())
  shopId    String
  message   String
  status    String   @default("OPEN") // OPEN | RESOLVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

// ─── UPGRADE REQUESTS (user → admin validation) ──────────────────────────────

model UpgradeRequest {
  id          String   @id @default(cuid())
  userId      String
  requestedPlan PlanType @default(PRO)
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedBy  String?
  reviewedAt  DateTime?
  rejectionReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("UpgradeReviews", fields: [reviewedBy], references: [id])
}

// ─── SHIPPING ZONE ──────────────────────────────────────────────────────────

model ShippingZone {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  price     Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

// ─── MARKETING ASSET ─────────────────────────────────────────────────────────

model MarketingAsset {
  id        String   @id @default(cuid())
  shopId    String
  type      String   // "QR_CODE", "STORY", "BUSINESS_CARD"
  template  String?
  config    String   @default("{}") // JSON config
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

// ─── BROADCAST MESSAGES ───────────────────────────────────────────────────────

model BroadcastMessage {
  id        String   @id @default(cuid())
  message   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── NOTIFICATION LOG ────────────────────────────────────────────────────────

model Notification {
  id          String   @id @default(cuid())
  type        String   // "NEW_SHOP" | "NEW_ORDER" | "NEW_SELLER" | "DOMAIN_REQUEST" | "SUPPORT_TICKET" | "LOW_STOCK" | "UPGRADE_REQUEST" | "SUSPENDED_USER" | "SHOP_LIVE"
  title       String
  message     String
  isRead      Boolean  @default(false)
  userId      String?
  metadata    String   @default("{}") // JSON: { shopId?, orderId?, userId?, shopName?, etc. }
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

// ─── PUSH SUBSCRIPTION (PWA) ──────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── FACEBOOK EVENT (Pixel + Conversions API) ────────────────────────────────

model FacebookEvent {
  id        String   @id @default(cuid())
  shopId    String
  eventName String   // PageView, ViewContent, Contact, Lead
  eventData String   // JSON string: { productId?, value?, currency?, contentName? }
  eventId   String   @unique // For deduplication between Pixel and CAPI
  source    String   @default("PIXEL") // PIXEL, CAPI, BOTH
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([eventName])
  @@index([createdAt])
}

// ─── SOCIAL POST (Facebook Publishing) ────────────────────────────────────

model SocialPost {
  id              String   @id @default(cuid())
  shopId          String
  platform        String   @default("FACEBOOK") // FACEBOOK | INSTAGRAM
  productId       String?  // Product that was published
  content         String   // Post text/message
  imageUrl        String?  // Image attached
  facebookPostId  String?  // ID returned by Graph API
  status          String   @default("PUBLISHED") // PUBLISHED | FAILED
  errorMessage    String?
  likes           Int      @default(0)
  comments        Int      @default(0)
  shares          Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop    Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([shopId])
  @@index([platform])
  @@index([createdAt])
}