// Boutiko SaaS - Multi-tenant e-commerce for African merchants
// Architecture: Subscription linked to USER (not shop), multi-shop per user, reseller white-label

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────────

enum Role {
  SELLER
  ADMIN
  SUPER_ADMIN
  RESELLER
}

enum PlanType {
  STARTER  // 5000F — 1 boutique
  PRO      // 8000F — 3 boutiques
  BUSINESS // 20000F — 10 boutiques + domaine personnalisé
}

enum SubStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

// ─── USER ──────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  role        Role     @default(SELLER)
  isSuspended Boolean  @default(false)
  suspendedAt DateTime?
  suspendedReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  shops           Shop[]
  orders          Order[]
  domainReviews   DomainRequest[] @relation("DomainReview")
  subscription    Subscription?
  resellerProfile Reseller?
  resellerClients User[]           @relation("ResellerClients")
  resellerId      String?
  reseller        User?            @relation("ResellerClients", fields: [resellerId], references: [id])
  upgradeRequests  UpgradeRequest[]
  reviewedUpgrades UpgradeRequest[] @relation("UpgradeReviews")
  notifications    Notification[]
}

// ─── SUBSCRIPTION (liée au COMPTE UTILISATEUR, pas à la boutique) ─────────────

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  planType         PlanType  @default(STARTER)
  status           SubStatus @default(TRIAL)
  maxShops         Int       @default(1)
  startDate        DateTime  @default(now())
  endDate          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── RESELLER (White-label) ────────────────────────────────────────────────────

model Reseller {
  id           String   @id @default(cuid())
  userId       String   @unique
  companyName  String?
  logoUrl      String?
  primaryColor String   @default("#EC4899")
  commission   Int      @default(10) // pourcentage de commission
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── SHOP (multi-boutiques par utilisateur) ────────────────────────────────────

model Shop {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String   @unique
  description           String?
  logo                  String?
  banner                String?
  whatsapp              String
  address               String?
  phone                 String?
  plan                  String   @default("FREE") // FREE | STANDARD | PRO (backward compat, kept for per-shop features)
  sector                String?  // beaute, mode, electronique, alimentation, artisanat, sport, bijoux, maison, auto, autre
  template              String   @default("classic")
  accentColor           String   @default("#25D366")
  isActive              Boolean  @default(true)
  ownerId               String   // NO @unique — allows multiple shops per user

  // SEO & Open Graph
  seoTitle              String?
  seoDescription        String?
  seoKeywords           String?
  ogImage               String?
  coverImageUrl         String?

  // Hero Slider (JSON array of image URLs)
  heroImages            String   @default("[]")

  // Promo Banners (JSON array of {image, title, link, position} objects)
  promoBanners          String   @default("[]")

  // Brands Carousel (JSON array of {name, image, link} objects)
  brands                String   @default("[]")

  // Custom Domain
  customDomain           String?   @unique
  customDomainStatus     String?   @default("NONE") // NONE | PENDING | APPROVED | REJECTED
  customDomainRejectionReason String?

  // Subscription (manual management — legacy, kept for backward compat)
  subscriptionStatus     String?   @default("TRIAL") // TRIAL | ACTIVE | SUSPENDED | EXPIRED | CANCELLED
  subscriptionEndDate    DateTime?

  // Referral
  referredById          String?

  // Marketing & Branding colors
  primaryColor          String   @default("#EC4899")
  secondaryColor        String?

  // Cosmika Beauty template customization
  heroTitle             String?
  heroSubtitle          String?
  heroTagline           String?
  heroImageUrl          String?
  productsTitle         String?
  productsTagline       String?
  categoriesTitle       String?
  categoriesTagline     String?
  testimonialsTitle     String?
  testimonialsTagline   String?
  trustBadges           String   @default("[]")  // JSON array of {emoji, title, subtitle, order}
  footerLinks           String   @default("[]")  // JSON array of {section, label, url}

  // Moderation
  isFlagged              Boolean   @default(false)
  flaggedReason          String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  owner     User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  referee  Shop?             @relation("Referral", fields: [referredById], references: [id])
  referrals Shop[]           @relation("Referral")
  categories   Category[]
  products     Product[]
  visits       Visit[]
  orders       Order[]
  liveSession  LiveSession?
  domainRequest DomainRequest?
  supportTickets SupportTicket[]
  shippingZones ShippingZone[]
  marketingAssets MarketingAsset[]
  testimonials   Testimonial[]
}

// ─── CATEGORY ──────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  image       String?
  shopId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products Product[]
}

// ─── TESTIMONIAL ─────────────────────────────────────────────────────────────

model Testimonial {
  id           String   @id @default(cuid())
  shopId       String
  clientName   String
  clientAvatar String?
  comment      String
  rating       Int      @default(5)
  isDisplayed  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

// ─── PRODUCT ───────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String?
  description String?
  price       Float
  image       String?
  images      String   @default("[]") // JSON array of image URLs
  stock       Int?
  isAvailable Boolean  @default(true)
  shopId      String
  categoryId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId, slug])

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

// ─── ORDER ─────────────────────────────────────────────────────────────────────

model Order {
  id              String   @id @default(cuid())
  shopId          String
  items           String   // JSON array of {productId, name, price, quantity}
  total           Float
  customerName    String?
  customerPhone   String?
  customerAddress String?
  status          String   @default("PENDING") // PENDING | CONFIRMED | DELIVERED | CANCELLED
  createdAt       DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])
  userId String?
}

// ─── VISIT ─────────────────────────────────────────────────────────────────────

model Visit {
  id        String   @id @default(cuid())
  shopId    String
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

// ─── LIVE SESSION ──────────────────────────────────────────────────────────────

model LiveSession {
  id              String   @id @default(cuid())
  shopId          String   @unique
  isActive        Boolean  @default(false)
  endTime         DateTime?
  pinnedProductId String?
  whatsappClicks  Int      @default(0)
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop        Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  promoCodes  LivePromoCode[]
  leads       Lead[]
}

model LivePromoCode {
  id              String   @id @default(cuid())
  sessionId       String
  code            String
  discountPercent Int
  isActive        Boolean  @default(true)
  usedCount       Int      @default(0)
  createdAt       DateTime @default(now())

  session     LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Lead {
  id        String   @id @default(cuid())
  sessionId String
  phone     String
  name      String?
  createdAt DateTime @default(now())

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ─── SaaS CONFIGURATION (Singleton) ────────────────────────────────────────────

model SaaSConfig {
  id                     String   @id @default(cuid())
  saasName               String   @default("Boutiko")
  primaryColor           String   @default("#EC4899")
  logoUrl                String?
  defaultWhatsappMessage String   @default("Bonjour, je souhaite commander le produit: {productName} - {productPrice} FCFA depuis votre boutique Boutiko.")
  // Plans pricing (FCFA)
  starterPrice           Int      @default(5000)
  proPrice               Int      @default(8000)
  businessPrice          Int      @default(20000)
  // Legacy fields (kept for backward compat)
  standardPrice          Int      @default(5000)
  proLegacyPrice         Int      @default(10000)
  adminWhatsAppNumber    String?
  // Notification settings
  supportEmail           String?
  senderName             String?
  autoWelcomeEmail       Boolean  @default(true)
  notifyNewSeller        Boolean  @default(true)
  notifyNewOrder         Boolean  @default(true)
  notifyDomainRequest    Boolean  @default(false)
  notifySupportTicket    Boolean  @default(true)
  weeklyReport           Boolean  @default(false)
  lowStockAlerts         Boolean  @default(false)
  // Moderation
  forbiddenKeywords     String   @default("") // JSON array of forbidden words for shop names, product names
  createdAt              DateTime @default(now())
  updatedAt              DateTime  @updatedAt
}

// ─── PROMO CODES (SaaS-level) ─────────────────────────────────────────────────

model PromoCode {
  id             String    @id @default(cuid())
  code           String    @unique
  discountPercent Int
  maxUses        Int
  currentUses    Int       @default(0)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── CUSTOM DOMAIN REQUESTS ────────────────────────────────────────────────────

model DomainRequest {
  id              String   @id @default(cuid())
  shopId          String   @unique
  domain          String   @unique
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectionReason String?
  dnsInstructions String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop    Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  reviewerId String?
  reviewer  User?   @relation("DomainReview", fields: [reviewerId], references: [id])
}

// ─── SUPPORT TICKETS ──────────────────────────────────────────────────────────

model SupportTicket {
  id        String   @id @default(cuid())
  shopId    String
  message   String
  status    String   @default("OPEN") // OPEN | RESOLVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

// ─── UPGRADE REQUESTS (user → admin validation) ──────────────────────────────

model UpgradeRequest {
  id          String   @id @default(cuid())
  userId      String
  requestedPlan PlanType @default(PRO)
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedBy  String?
  reviewedAt  DateTime?
  rejectionReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("UpgradeReviews", fields: [reviewedBy], references: [id])
}

// ─── SHIPPING ZONE ──────────────────────────────────────────────────────────

model ShippingZone {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  price     Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

// ─── MARKETING ASSET ─────────────────────────────────────────────────────────

model MarketingAsset {
  id        String   @id @default(cuid())
  shopId    String
  type      String   // "QR_CODE", "STORY", "BUSINESS_CARD"
  template  String?
  config    String   @default("{}") // JSON config
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

// ─── BROADCAST MESSAGES ───────────────────────────────────────────────────────

model BroadcastMessage {
  id        String   @id @default(cuid())
  message   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── NOTIFICATION LOG ────────────────────────────────────────────────────────

model Notification {
  id          String   @id @default(cuid())
  type        String   // "NEW_SHOP" | "NEW_ORDER" | "NEW_SELLER" | "DOMAIN_REQUEST" | "SUPPORT_TICKET" | "LOW_STOCK" | "UPGRADE_REQUEST" | "SUSPENDED_USER" | "SHOP_LIVE"
  title       String
  message     String
  isRead      Boolean  @default(false)
  userId      String?
  metadata    String   @default("{}") // JSON: { shopId?, orderId?, userId?, shopName?, etc. }
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@index([userId])
}