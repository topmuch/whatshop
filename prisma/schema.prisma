// WhatsShop SaaS - Multi-tenant e-commerce for African merchants

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("SELLER") // SELLER | ADMIN | SUPER_ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop     Shop?
  orders   Order[]
  domainReviews DomainRequest[] @relation("DomainReview")
}

model Shop {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String   @unique
  description           String?
  logo                  String?
  banner                String?
  whatsapp              String
  address               String?
  phone                 String?
  plan                  String   @default("FREE") // FREE | STANDARD | PRO
  sector                String?  // beaute, mode, electronique, alimentation, artisanat, sport, bijoux, maison, auto, autre
  template              String   @default("classic") // classic | africa | minimal | elegant | neon | rose | ocean | sunset | jameela | xstore-fashion | xstore-electro | xstore-grocery | electrodepot
  isActive              Boolean  @default(true)
  ownerId               String   @unique

  // SEO & Appearance
  seoTitle              String?
  seoDescription        String?
  coverImageUrl         String?

  // Hero Slider (JSON array of image URLs)
  heroImages            String   @default("[]")

  // Promo Banners (JSON array of {image, title, link, position} objects)
  promoBanners          String   @default("[]")

  // Custom Domain
  customDomain           String?   @unique
  customDomainStatus     String?   @default("NONE") // NONE | PENDING | APPROVED | REJECTED
  customDomainRejectionReason String?

  // Subscription (manual management)
  subscriptionStatus     String?   @default("TRIAL") // TRIAL | ACTIVE | SUSPENDED | EXPIRED | CANCELLED
  subscriptionEndDate    DateTime?

  // Referral
  referredById          String?

  // Moderation
  isFlagged              Boolean   @default(false)
  flaggedReason          String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  owner     User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  referee  Shop?             @relation("Referral", fields: [referredById], references: [id])
  referrals Shop[]           @relation("Referral")
  categories   Category[]
  products     Product[]
  visits       Visit[]
  orders       Order[]
  liveSession  LiveSession?
  domainRequest DomainRequest?
  supportTickets SupportTicket[]
}

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  shopId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  image       String?
  images      String   @default("[]") // JSON array of image URLs
  stock       Int?
  isAvailable Boolean  @default(true)
  shopId      String
  categoryId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model Order {
  id              String   @id @default(cuid())
  shopId          String
  items           String   // JSON array of {productId, name, price, quantity}
  total           Float
  customerName    String?
  customerPhone   String?
  customerAddress String?
  status          String   @default("PENDING") // PENDING | CONFIRMED | DELIVERED | CANCELLED
  createdAt       DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])
  userId String?
}

model Visit {
  id        String   @id @default(cuid())
  shopId    String
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model LiveSession {
  id              String   @id @default(cuid())
  shopId          String   @unique
  isActive        Boolean  @default(false)
  endTime         DateTime?
  pinnedProductId String?
  whatsappClicks  Int      @default(0)
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop        Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  promoCodes  LivePromoCode[]
  leads       Lead[]
}

model LivePromoCode {
  id              String   @id @default(cuid())
  sessionId       String
  code            String
  discountPercent Int
  isActive        Boolean  @default(true)
  usedCount       Int      @default(0)
  createdAt       DateTime @default(now())

  session     LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Lead {
  id        String   @id @default(cuid())
  sessionId String
  phone     String
  name      String?
  createdAt DateTime @default(now())

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ─── NEW: SaaS Configuration (Singleton) ──────────────────────────────────────

model SaaSConfig {
  id                     String   @id @default(cuid())
  saasName               String   @default("WhatsShop")
  primaryColor           String   @default("#EC4899")
  logoUrl                String?
  defaultWhatsappMessage String   @default("Bonjour, je souhaite commander le produit: {productName} - {productPrice} FCFA depuis votre boutique WhatsShop.")
  standardPrice          Int      @default(5000)
  proPrice               Int      @default(10000)
  adminWhatsAppNumber    String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// ─── NEW: Promo Codes (SaaS-level) ─────────────────────────────────────────────

model PromoCode {
  id             String    @id @default(cuid())
  code           String    @unique
  discountPercent Int
  maxUses        Int
  currentUses    Int       @default(0)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── NEW: Custom Domain Requests ───────────────────────────────────────────────

model DomainRequest {
  id              String   @id @default(cuid())
  shopId          String   @unique
  domain          String   @unique
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectionReason String?
  dnsInstructions String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop    Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  reviewerId String?
  reviewer  User?   @relation("DomainReview", fields: [reviewerId], references: [id])
}

// ─── NEW: Support Tickets ──────────────────────────────────────────────────────

model SupportTicket {
  id        String   @id @default(cuid())
  shopId    String
  message   String
  status    String   @default("OPEN") // OPEN | RESOLVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

// ─── NEW: Broadcast Messages ───────────────────────────────────────────────────

model BroadcastMessage {
  id        String   @id @default(cuid())
  message   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
