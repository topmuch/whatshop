# ─────────────────────────────────────────────────────────────
# Boutiko - Environment Configuration for Coolify / Production
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# SQLite (default - file-based, no external DB needed)
DATABASE_URL=file:./db/boutiko.db

# ── App ──────────────────────────────────────────────────────
# Port the app listens on (default: 3000)
PORT=3000
HOSTNAME=0.0.0.0

# ── Security (REQUIRED — generate new values for production) ──
# SESSION_SECRET: Signs and encrypts user session cookies (iron-session).
#   Generate with: openssl rand -base64 48
#   Must be ≥32 characters.
SESSION_SECRET=

# FACEBOOK_TOKEN_ENCRYPTION_KEY: AES-256-GCM key to encrypt Facebook
#   access tokens stored in the database. Each environment (dev/staging/prod)
#   MUST use a different key. Must be ≥16 characters.
FACEBOOK_TOKEN_ENCRYPTION_KEY=

# COOKIE_SECURE=true  (uncomment for HTTPS / production with custom domain)

# ── AI Features (optional) ─────────────────────────────────
# z-ai-web-dev-sdk API key for AI content generation
# Z_AI_API_KEY=your-api-key-here

# ── Domain (Coolify) ─────────────────────────────────────────
# Set this if deploying with a custom domain via Coolify
# NEXT_PUBLIC_APP_URL=https://boutiko.pro

# ── File Uploads ──────────────────────────────────────────────
# Directory for uploaded files (images, logos, etc.)
# Docker / Coolify: must be a persistent volume path
UPLOADS_DIR=/app/uploads

# ── Email / SMTP (optional — if not set, emails are disabled) ─
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=Boutiko <noreply@boutiko.pro>
# EMAIL_FROM_NAME=Boutiko
# SUPPORT_EMAIL=support@boutiko.pro

# ── Push Notifications (optional) ─────────────────────────────
# Generate VAPID keys with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=