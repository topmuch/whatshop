# ─── Database ───────────────────────────────────────────────────────────
DATABASE_URL=file:./db/custom.db

# ─── Security (REQUIRED — generate new values for production) ──────────
# Generate with: openssl rand -base64 48
SESSION_SECRET=
FACEBOOK_TOKEN_ENCRYPTION_KEY=

# ─── Facebook Integration (optional — required for Facebook/Instagram connect) ──
# Create a Facebook App at https://developers.facebook.com and add the Facebook Login product.
# Set the OAuth redirect URI to: https://your-domain.com/api/facebook/oauth/callback
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# ─── Super Admin (optional — for first-time setup) ─────────────────────
# SUPER_ADMIN_EMAIL=
# SUPER_ADMIN_PASSWORD=
# SUPER_ADMIN_NAME=Super Admin

# ─── Wave Payments (optional — for subscription & order payments) ───
# Clé API Wave Business de Boutiko (pour les paiements d'abonnements)
# WAVE_API_KEY=
# Secret pour vérifier les webhooks Wave
# WAVE_WEBHOOK_SECRET=
# URL de base de l'API Wave (par défaut: https://api.wave.com/v1)
# WAVE_API_BASE_URL=

# ─── App ───────────────────────────────────────────────────────────────
# NEXT_PUBLIC_BASE_URL=https://boutiko.pro
# COOKIE_SECURE=true